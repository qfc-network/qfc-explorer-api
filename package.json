{
  "name": "qfc-explorer-api",
  "version": "1.0.0",
  "description": "QFC Blockchain Explorer API — Fastify + TypeScript backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:indexer": "node dist/indexer/index.js",
    "indexer": "tsx src/indexer/index.ts",
    "indexer:dev": "tsx watch src/indexer/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.3.3",
    "ioredis": "^5.10.0",
    "js-sha3": "^0.9.3",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
