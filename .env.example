# Database
DATABASE_URL=postgres://user:pass@localhost:5432/qfc_explorer
DATABASE_REPLICA_URL=                    # Read replica (optional, falls back to primary)

# RPC — comma-separated for multi-node round-robin
RPC_URL=http://127.0.0.1:8545
RPC_ARCHIVE_URL=                         # Archive node for debug_traceTransaction (optional)

# Redis
REDIS_URL=redis://localhost:6379

# API Server
PORT=3001
HOST=0.0.0.0
SSE_INTERVAL_MS=5000

# Indexer settings
INDEXER_START_HEIGHT=0
INDEXER_POLL_INTERVAL_MS=10000
INDEXER_USE_FINALIZED=true
INDEXER_BLOCK_RETRIES=3
INDEXER_SKIP_ON_ERROR=false
INDEXER_RETRY_FAILED=false
